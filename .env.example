# Server identity / OAuth ----------------------------------------------------

# Public origin where this server is reachable. MUST be HTTPS in production
# (Claude.ai requires HTTPS for remote MCP). No trailing /mcp path.
MCP_BASE_URL=https://tools-mcp.example.com

# OAuth client identifier the MCP client (e.g. Claude.ai) sends.
MCP_CLIENT_ID=dev

# The approval page at /authorize must be guarded — the server refuses to start
# unless one of the three guards below is set.

# Password shown on the /authorize approval page; a code is issued only when the
# correct password is posted. The simplest guard for a first-party deployment.
APPROVAL_PASSWORD=

# Optional client secret — when set, clients must include the same value at token
# exchange (/token). Also satisfies the approval guard on its own. Leave blank for
# public-client (PKCE-only) flow.
MCP_CLIENT_SECRET=

# Set to true only when a reverse proxy / zero-trust gateway already guards
# /authorize; it declares the approval page acceptably fronted (click-to-approve,
# no password). Leave blank otherwise.
APPROVAL_OPEN=

# Optional fixed bearer token for clients that bypass the browser OAuth flow
# (mcp-remote, curl, scripts). Generate with: openssl rand -hex 32
MCP_STATIC_BEARER_TOKEN=

# Optional bearer for the /health liveness probe. Leave blank and /health returns
# 404; set it and /health requires this token. Rotates independently of MCP auth.
HEALTH_TOKEN=

# Comma-separated list of additional allowed redirect URIs. Claude.ai's
# callback is included by default; add others (e.g. Antigravity) as needed.
# MCP_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# Comma-separated CORS origins (or `*`). Include the MCP client origin.
CORS_ALLOWED_ORIGINS=https://claude.ai

# HTTP port the server listens on. Reverse-proxy this to MCP_BASE_URL via TLS.
PORT=3457

# Where to persist OAuth access tokens across restarts.
# TOKEN_STORE_PATH=./tokens.json

# Bird (X/Twitter CLI) credentials -------------------------------------------
# Extract once from a logged-in browser; rotate when bird starts returning
# auth errors. Never commit these.
BIRD_AUTH_TOKEN=
BIRD_CT0=

# Perplexity API key ---------------------------------------------------------
# Get from https://www.perplexity.ai/account/api/group. Used by the
# perplexity_search / perplexity_ask / perplexity_research / perplexity_reason
# tools. Calls bill to whichever key is set here.
PERPLEXITY_API_KEY=
# Optional — override the per-request timeout (default 300000ms / 5 min).
# Raise it if perplexity_research times out.
# PERPLEXITY_TIMEOUT_MS=300000

# Cloudflare Browser Rendering (Browser Run) ---------------------------------
# Powers the browser_* tools (markdown, content, screenshot, scrape, links,
# snapshot). Calls bill to this account's browser-time quota (free plan: 10
# min/day, 3 concurrent browsers).
# Account ID: Cloudflare dashboard → Workers & Pages → Overview.
CLOUDFLARE_ACCOUNT_ID=
# API token with the "Browser Rendering — Edit" permission:
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
# Optional — override the per-request timeout (default 120000ms / 2 min).
# CLOUDFLARE_API_BASE defaults to https://api.cloudflare.com/client/v4.
# BROWSER_RENDERING_TIMEOUT_MS=120000
