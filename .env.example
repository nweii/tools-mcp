# Server identity / OAuth ----------------------------------------------------

# Public origin where this server is reachable. MUST be HTTPS in production
# (Claude.ai requires HTTPS for remote MCP). No trailing /mcp path.
MCP_BASE_URL=https://tools-mcp.example.com

# OAuth client identifier the MCP client (e.g. Claude.ai) sends.
MCP_CLIENT_ID=dev

# Optional client secret — when set, clients must include the same value on
# /oauth/token. Leave blank for public-client (PKCE-only) flow.
MCP_CLIENT_SECRET=

# Optional fixed bearer token for clients that bypass the browser OAuth flow
# (mcp-remote, curl, scripts). Generate with: openssl rand -hex 32
MCP_STATIC_BEARER_TOKEN=

# Comma-separated list of additional allowed redirect URIs. Claude.ai's
# callback is included by default; add others (e.g. Antigravity) as needed.
# MCP_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# Comma-separated CORS origins (or `*`). Include the MCP client origin.
CORS_ALLOWED_ORIGINS=https://claude.ai

# HTTP port the server listens on. Reverse-proxy this to MCP_BASE_URL via TLS.
PORT=3457

# Where to persist OAuth access tokens across restarts.
# TOKEN_STORE_PATH=./tokens.json

# Bird (X/Twitter CLI) credentials -------------------------------------------
# Extract once from a logged-in browser; rotate when bird starts returning
# auth errors. Never commit these.
BIRD_AUTH_TOKEN=
BIRD_CT0=
