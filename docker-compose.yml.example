services:
  tools-mcp:
    image: oven/bun:1
    working_dir: /app
    restart: unless-stopped
    environment:
      MCP_BASE_URL: https://tools-mcp.example.com
      MCP_CLIENT_ID: your-client-id
      MCP_CLIENT_ALLOWED_REDIRECT_URIS: https://claude.ai/api/mcp/auth_callback
      MCP_DCR_ALLOWED_REDIRECT_URIS: ""                 # Set public-client callbacks to enable DCR.
      APPROVAL_PASSWORD: your-approval-password        # guards /authorize — required unless MCP_CLIENT_SECRET or APPROVAL_OPEN is set (server refuses to boot unguarded)
      MCP_CLIENT_SECRET: ""                            # optional; also satisfies the /authorize guard
      MCP_STATIC_BEARER_TOKEN: ""                      # optional, generate with: openssl rand -hex 32
      HEALTH_TOKEN: ""                                 # optional; set to enable the bearer-gated /health probe
      CORS_ALLOWED_ORIGINS: https://claude.ai
      PORT: 3457
      BIRD_AUTH_TOKEN: ${BIRD_AUTH_TOKEN}              # set in your .env or Portainer stack env
      BIRD_CT0: ${BIRD_CT0}
      PERPLEXITY_API_KEY: ${PERPLEXITY_API_KEY}
      CLOUDFLARE_ACCOUNT_ID: ${CLOUDFLARE_ACCOUNT_ID}  # Browser Rendering — account ID
      CLOUDFLARE_API_TOKEN: ${CLOUDFLARE_API_TOKEN}    # Browser Rendering — Edit token
      # TOKEN_STORE_PATH: /app/data/tokens.json        # uncomment to persist OAuth tokens
    volumes:
      - ./:/app
      # - ./data:/app/data
    command: ["sh", "-c", "bun install --production && bun run src/server.ts"]
    ports:
      - "3457:3457"
