{
  "name": "tools-mcp",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "description": "Personal MCP toolkit — exposes wrapped local CLIs and remote APIs (bird, Perplexity, …) as MCP tools for remote use from Claude.ai and other MCP clients.",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts",
    "test": "TOOLS_MCP_TEST=1 bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@steipete/bird": "^0.8.0",
    "express": "^4.21.2",
    "mcp-server-kit": "git+https://github.com/nweii/mcp-server-kit.git",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.1.0"
  }
}
